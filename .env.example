# ============================================================
# DeepSeek Mirror 配置模板
# 复制为 .env 并填入实际值（.env 已被 .gitignore 忽略）
# ============================================================

# ----- 服务端口 -----
PORT=3000

# ----- Session 密钥（必填，至少 32 字符）-----
# 生成方法：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# 留空将导致服务启动失败
SESSION_SECRET=

# ----- 数据库加密密钥（必填，PR-0 引入）-----
# 用于 AES-256-GCM 加密 accounts 表中的 token / cookies
# 留空将导致服务启动失败（首次引入该字段时旧数据将自动迁移）
DB_ENCRYPT_KEY=

# ----- 管理员凭据（可选）-----
# 若 ADMIN_PASSWORD 留空或为默认值 "admin"，启动时将自动生成临时密码并打印
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----- Cookie 安全（可选）-----
# 仅在 HTTPS 部署时设为 true（默认 production 模式下自动启用）
COOKIE_SECURE=false

# ----- 运行环境 -----
# 不设置时默认 production；可在 .env 中覆盖为 development
# NODE_ENV=production
